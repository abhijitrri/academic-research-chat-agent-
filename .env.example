# LLM Provider Configuration
# Options: 'openai' (default) or 'anthropic'
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Anthropic Configuration (optional, set LLM_PROVIDER=anthropic to use)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-1

# Database
DATABASE_URL=postgresql://research_user:research_pass@localhost:5432/research_agent_db

# Redis
REDIS_URL=redis://localhost:6379

# File Storage
DATA_DIR=./data

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=INFO
